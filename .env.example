# DeepSeek API Key (Required for DeepSeek-compatible usage)
# Get yours at https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-key-here

# Default Model (Optional)
# Options: deepseek-chat, deepseek-coder
DEEPSEEK_MODEL=deepseek-chat

# Max Context Tokens (Optional)
DEEPSEEK_MAX_CONTEXT=64000

# Debug Mode (0 or 1)
DEEPSEEK_DEBUG=0
